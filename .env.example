# Copy to .env.local and fill in.

# Pooled Neon connection string — use the "Pooled connection" from the Neon console.
DATABASE_URL=postgresql://USER:PASSWORD@ep-XXXX-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# Neon Auth — values from Neon Console → Auth → Configuration.
NEON_AUTH_BASE_URL=https://ep-XXXX.neonauth.REGION.aws.neon.tech/neondb/auth
# Generate locally with: openssl rand -base64 48
NEON_AUTH_COOKIE_SECRET=at-least-32-characters-of-random
